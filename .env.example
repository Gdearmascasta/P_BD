# =========================================================================
# OPERATIONAL ENV CONFIGS - SCADA PLATFORM
# =========================================================================

# Database Connection URL
# ------------------------
# FALLBACK: If DATABASE_URL is empty or not set, the platform transparently 
# falls back to a local SQLite database (sensors_local.db) in the root.
#
# Production (PostgreSQL Asyncpg):
DATABASE_URL=postgresql+asyncpg://postgres:password123@localhost:5432/scada_db

# Application Configuration
# --------------------------
# Exposing port for the single container deployment
PORT=8000
